<?xml version="1.0" encoding="utf-8"?>
<plugin xmlns="http://www.phonegap.com/ns/plugins/1.0"
        id="com.ashera.spatialkit.web"
        version="1.0">

  <name>CordovaSpatialKitPlugin</name>

  <engines>
    <engine name="cordova" version=">=3.4.0"/>
  </engines>
  
  <platform name="browser">
    <config-file target="config.xml" parent="/*">
      <feature name="CordovaSpatialKitPlugin">
        <param name="android-package" value="com.ashera.spatialkit.CordovaSpatialKitPlugin"/>
        <param name="onload" value="true" />
      </feature>
    </config-file>
	<framework src="core.gradle" custom="true" type="gradleReference" />
	<js-module src="www/js/add_res.js" name="mapAddRes">
    	 <runs/>
  	</js-module>
   	 <!-- start src -->
     <!-- src end -->
     <!-- start res -->
     <!-- res end -->
     <!-- start tsc -->
     <source-file src="tsc/src/web/widget/CompassViewImpl.ts" target-dir="tsc/src/web/widget"/>
     <source-file src="tsc/src/web/widget/MapViewImpl.ts" target-dir="tsc/src/web/widget"/>
     <!-- tsc end -->
  </platform>


</plugin>